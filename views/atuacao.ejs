<%- include('partials/header', { currentPage: 'atuacao' }) %>

<!-- ===== HERO ATUAÇÃO ===== -->
<section class="hero-section" style="min-height: 50vh; padding: 140px 0 60px;">
    <div class="container position-relative z-1">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center" data-aos="fade-up">
                <div class="hero-badge justify-content-center">
                    <span class="dot"></span>
                    Áreas de Atuação
                </div>
                <h1 class="hero-title">
                    Direito Tributário<br>
                    <span class="highlight">em Todas as suas Dimensões</span>
                </h1>
                <p class="hero-subtitle mx-auto">
                    Da consultoria preventiva ao contencioso fiscal, oferecemos soluções completas 
                    em Direito Tributário para proteger seus direitos e otimizar sua carga tributária.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- ===== ÁREAS DETALHADAS ===== -->
<section class="section-padding bg-dark-surface">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <div class="section-divider"></div>
            <h2 class="section-title">Nossas Especialidades</h2>
            <p class="section-subtitle">Conheça as áreas em que podemos ajudar você</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="100">
                <div class="atuacao-card">
                    <div class="icon"><i class="bi bi-graph-up-arrow"></i></div>
                    <h5>Planejamento Tributário</h5>
                    <p>Elaboração de estratégias legais para redução da carga tributária, escolha do regime fiscal adequado e estruturação societária otimizada.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="150">
                <div class="atuacao-card">
                    <div class="icon"><i class="bi bi-shield-shaded"></i></div>
                    <h5>Contencioso Fiscal</h5>
                    <p>Atuação em processos administrativos e judiciais, defesa em execuções fiscais, impugnações e recursos nas esferas municipal, estadual e federal.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="200">
                <div class="atuacao-card">
                    <div class="icon"><i class="bi bi-file-text"></i></div>
                    <h5>Consultoria Jurídica Preventiva</h5>
                    <p>Assessoria contínua para empresas, análise de riscos fiscais, elaboração de contratos e pareceres técnicos em matéria tributária.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="250">
                <div class="atuacao-card">
                    <div class="icon"><i class="bi bi-bank"></i></div>
                    <h5>Direito Tributário Empresarial</h5>
                    <p>Assessoria completa para empresas: tributos federais, estaduais e municipais, regimes especiais, benefícios fiscais e recuperação de créditos.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="300">
                <div class="atuacao-card">
                    <div class="icon"><i class="bi bi-person-check"></i></div>
                    <h5>Direito do Contribuinte</h5>
                    <p>Defesa dos direitos do contribuinte perante o Fisco, revisão de lançamentos tributários, restituição de impostos pagos indevidamente.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="350">
                <div class="atuacao-card">
                    <div class="icon"><i class="bi bi-journal-bookmark-fill"></i></div>
                    <h5>Pesquisa & Academia</h5>
                    <p>Produção de artigos científicos, estudos aprofundados sobre reforma tributária e temas emergentes do direito fiscal brasileiro.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== CTA ===== -->
<section class="section-padding">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center" data-aos="fade-up">
                <h2 class="section-title">Precisa de Ajuda com uma Questão Tributária?</h2>
                <p class="section-subtitle">Agende uma consultoria personalizada e descubra como podemos ajudar.</p>
                <a href="/consultoria" class="btn btn-gold btn-lg rounded-pill px-5 mt-3">
                    <i class="bi bi-calendar-check me-2"></i>Agendar Consultoria
                </a>
            </div>
        </div>
    </div>
</section>

