<%- include('../partials/header') %>
<div class="dashboard-page">
    <div class="dashboard-header">
        <div class="container">
            <div class="row align-items-center">
                <div class="col dashboard-welcome">
                    <h4><i class="bi bi-envelope-paper text-gold me-2"></i>Inscritos Newsletter</h4>
                </div>
                <div class="col-auto">
                    <a href="/admin/dashboard" class="btn btn-glass btn-sm rounded-pill">
                        <i class="bi bi-arrow-left me-1"></i>Voltar
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="container py-4">
        <div class="card-premium p-4" data-aos="fade-up">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted">Total: <strong class="text-gold"><%= inscritos.length %></strong> inscritos</span>
                <a href="mailto:<%= inscritos.map(i => i.email).join(';') %>" class="btn btn-sm btn-glass rounded-pill">
                    <i class="bi bi-send me-1"></i>Enviar E-mail para Todos
                </a>
            </div>
            <div class="table-responsive">
                <table class="table table-premium mb-0">
                    <thead>
                        <tr><th>Nome</th><th>E-mail</th><th>Data</th><th>Ativo</th><th>Ações</th></tr>
                    </thead>
                    <tbody>
                        <% inscritos.forEach(function(i) { %>
                        <tr>
                            <td><%= i.nome || '—' %></td>
                            <td><%= i.email %></td>
                            <td><small><%= i.criado_em %></small></td>
                            <td>
                                <% if (i.ativo) { %>
                                    <span class="badge bg-success">Ativo</span>
                                <% } else { %>
                                    <span class="badge bg-secondary">Inativo</span>
                                <% } %>
                            </td>
                            <td>
                                <form action="/admin/newsletter/excluir/<%= i.id %>" method="POST" data-confirm="Remover?" style="display:inline">
                                    <button type="submit" class="btn btn-sm btn-glass" style="color:var(--accent)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<%- include('../partials/footer') %>
